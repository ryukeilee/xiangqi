#!/usr/bin/env bash
# ============================================================
# pre-commit — 扫描暂存区中的敏感信息，发现即阻止提交
# 兼容 bash 3.2+（macOS 默认 BSD grep）
# 可通过 `SKIP_SECRET_SCAN=1 git commit ...` 跳过（慎用）
# ============================================================

set -eu

if [[ "${SKIP_SECRET_SCAN:-}" == "1" ]]; then
  echo "⚠️  已跳过密钥扫描 (SKIP_SECRET_SCAN=1)"
  exit 0
fi

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

FOUND_SECRET=0

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if [[ -z "$STAGED_FILES" ]]; then
  exit 0
fi

# -------- 匹配函数：返回 0 表示命中 --------
match() {
  # $1=line, $2=ERE pattern
  echo "$1" | grep -qE -e "$2" 2>/dev/null
}

# -------- 扫描单行 --------
scan_line() {
  local line="$1"
  local file="$2"
  local lineno="$3"

  local label=""

  # 按危险程度排序 — 高特异性优先
  if match "$line" 'AKIA[0-9A-Z]{16}'; then
    label="AWS Access Key ID"
  elif match "$line" 'ghp_[0-9a-zA-Z]{36}'; then
    label="GitHub Personal Access Token"
  elif match "$line" 'gho_[0-9a-zA-Z]{36}'; then
    label="GitHub OAuth Token"
  elif match "$line" 'gh[usr]_[0-9a-zA-Z]{36}'; then
    label="GitHub Token"
  elif match "$line" 'sk-ant-[a-zA-Z0-9\-]{20,}'; then
    label="Anthropic API Key"
  elif match "$line" 'sk-[a-zA-Z0-9\-]{25,}'; then
    label="AI API Key (OpenAI/Claude 等)"
  elif match "$line" '-----BEGIN (RSA|EC|DSA|OPENSSH) PRIVATE KEY-----'; then
    label="Private Key (PEM)"
  elif match "$line" 'eyJ[a-zA-Z0-9_\-]{20,}\.[a-zA-Z0-9_\-]{20,}\.[a-zA-Z0-9_\-]{1,}'; then
    label="JWT Token"
  elif match "$line" '(mongodb|mysql|postgres|postgresql|redis)://[^:]+:[^@]+@'; then
    label="数据库连接字符串(含密码)"
  elif match "$line" 'api[_-]?key\s*[:=]\s*['\''"]?[a-zA-Z0-9_\-]{16,}'; then
    label="API Key 明文赋值"
  elif match "$line" '(secret|Secret|SECRET)\s*[:=]\s*['\''"]?[a-zA-Z0-9_\-]{8,}'; then
    label="Secret 明文赋值"
  elif match "$line" 'password\s*[:=]\s*['\''"]?[^'\''"]{4,}'; then
    label="Password 明文赋值"
  elif match "$line" 'token\s*[:=]\s*['\''"]?[a-zA-Z0-9_\-\.]{20,}'; then
    label="Token 明文赋值"
  fi

  if [[ -n "$label" ]]; then
    if [[ $FOUND_SECRET -eq 0 ]]; then
      echo ""
      echo -e "${RED}╔══════════════════════════════════════════════════════════╗${NC}"
      echo -e "${RED}║  🔴 发现疑似敏感信息！提交已被阻止。                    ║${NC}"
      echo -e "${RED}╚══════════════════════════════════════════════════════════╝${NC}"
      echo ""
    fi
    FOUND_SECRET=1
    echo -e "${YELLOW}📄 ${file}:${lineno}${NC} — ${RED}${label}${NC}"
    echo "   ${line}"
  fi
}

# -------- 扫描单个文件 --------
scan_file() {
  local file="$1"
  local content
  content=$(git show ":$file" 2>/dev/null || true)
  if [[ -z "$content" ]]; then
    return
  fi

  local lineno=0
  while IFS= read -r line; do
    lineno=$((lineno + 1))
    scan_line "$line" "$file" "$lineno"
  done <<< "$content"
}

# -------- 遍历暂存文件 --------
for file in $STAGED_FILES; do
  if git check-ignore -q "$file" 2>/dev/null; then
    continue
  fi
  scan_file "$file"
done

if [[ $FOUND_SECRET -eq 1 ]]; then
  echo ""
  echo -e "${YELLOW}💡 提示：${NC}"
  echo "   • 假阳性 → env SKIP_SECRET_SCAN=1 git commit ..."
  echo "   • 测试数据 → 移入 .env.example，用占位符替换"
  echo "   • 真实密钥 → 立即轮换！已暂存的内容可能已泄露"
  echo ""
  exit 1
fi

exit 0
