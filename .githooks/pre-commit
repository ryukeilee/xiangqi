#!/usr/bin/env bash
# ============================================================
# pre-commit — 扫描暂存区中的敏感信息，发现即阻止提交
# 可通过 `SKIP_SECRET_SCAN=1 git commit ...` 跳过（慎用）
# ============================================================

set -euo pipefail

# 用户可通过环境变量跳过扫描
if [[ "${SKIP_SECRET_SCAN:-}" == "1" ]]; then
  echo "⚠️  已跳过密钥扫描 (SKIP_SECRET_SCAN=1)"
  exit 0
fi

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

FOUND_SECRET=0
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [[ -z "$STAGED_FILES" ]]; then
  exit 0
fi

# -------- 模式定义 --------
# 每条规则: "正则" "描述"
declare -A PATTERNS=(
  # AWS
  ["AKIA[0-9A-Z]{16}"]="AWS Access Key ID (AKIA...)"
  ["(?i)aws_secret_access_key\\s*[:=]\\s*['\"]?[^'\"]{10,}"]="AWS Secret Access Key"

  # GitHub
  ["ghp_[0-9a-zA-Z]{36}"]="GitHub Personal Access Token (ghp_...)"
  ["gho_[0-9a-zA-Z]{36}"]="GitHub OAuth Token (gho_...)"
  ["ghu_[0-9a-zA-Z]{36}"]="GitHub User Token (ghu_...)"
  ["ghs_[0-9a-zA-Z]{36}"]="GitHub Server Token (ghs_...)"
  ["ghr_[0-9a-zA-Z]{36}"]="GitHub Refresh Token (ghr_...)"

  # OpenAI / Claude / AI
  ["sk-[a-zA-Z0-9]{20,}"]="OpenAI / AI API Key (sk-...)"
  ["sk-ant-[a-zA-Z0-9]{20,}"]="Anthropic API Key (sk-ant-...)"

  # 通用密钥模式
  ["-----BEGIN (RSA|EC|DSA|OPENSSH) PRIVATE KEY-----"]="Private Key (PEM)"
  ["(?i)api[_-]?key\\s*[:=]\\s*['\"]?[a-zA-Z0-9_\\-]{20,}['\"]?"]="API Key 赋值"
  ["(?i)secret\\s*[:=]\\s*['\"]?[a-zA-Z0-9_\\-]{10,}['\"]?"]="Secret 明文赋值"
  ["(?i)password\\s*[:=]\\s*['\"]?[^'\"]+['\"]?"]="Password 明文赋值"
  ["(?i)token\\s*[:=]\\s*['\"]?[a-zA-Z0-9_\\-\\.]{20,}['\"]?"]="Token 明文赋值"

  # JWT
  ["eyJ[a-zA-Z0-9_\\-]{20,}\\.[a-zA-Z0-9_\\-]{20,}\\.[a-zA-Z0-9_\\-]{1,}"]="JWT Token"

  # 数据库连接串
  ["(?i)(mongodb|mysql|postgres|postgresql|redis|sqlite)://[^:]+:[^@]+@"]="数据库连接字符串(含密码)"

  # 私钥文件格式
  ["(?i)private[_-]?key"]="private_key 引用"
)

# -------- 扫描 --------
for file in $STAGED_FILES; do
  # 跳过二进制
  if [[ -n "$file" ]] && file "$file" 2>/dev/null | grep -qE '(binary|ELF|Mach-O|archive)'; then
    continue
  fi

  # 跳过 .gitignore 中已忽略的文件（二次保险）
  if git check-ignore -q "$file" 2>/dev/null; then
    continue
  fi

  for pattern in "${!PATTERNS[@]}"; do
    desc="${PATTERNS[$pattern]}"
    # 用 git show 读暂存区内容
    matches=$(git show ":$file" 2>/dev/null | grep -n -E "$pattern" || true)
    if [[ -n "$matches" ]]; then
      if [[ $FOUND_SECRET -eq 0 ]]; then
        echo ""
        echo -e "${RED}╔══════════════════════════════════════════════════════════╗${NC}"
        echo -e "${RED}║  🔴 发现疑似敏感信息！提交已被阻止。                    ║${NC}"
        echo -e "${RED}╚══════════════════════════════════════════════════════════╝${NC}"
        echo ""
      fi
      FOUND_SECRET=1
      echo -e "${YELLOW}📄 ${file}${NC} — ${RED}${desc}${NC}"
      while IFS= read -r line; do
        echo "   ${line}"
      done <<< "$matches"
      echo ""
    fi
  done
done

if [[ $FOUND_SECRET -eq 1 ]]; then
  echo -e "${YELLOW}💡 提示：${NC}"
  echo "   • 如果是假阳性，用环境变量跳过: SKIP_SECRET_SCAN=1 git commit ..."
  echo "   • 如果是测试数据，移入 .env.example 并用占位符替换"
  echo "   • 如果是真实密钥，立即轮换！已暂存的内容可能已泄露到日志"
  echo ""
  exit 1
fi

exit 0
