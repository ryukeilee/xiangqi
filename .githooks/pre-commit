#!/usr/bin/env bash
# ============================================================
# pre-commit — 扫描暂存区中的敏感信息，发现即阻止提交
# 兼容 bash 3.2+（macOS 默认版本）
# 可通过 `SKIP_SECRET_SCAN=1 git commit ...` 跳过（慎用）
# ============================================================

set -euo pipefail

if [[ "${SKIP_SECRET_SCAN:-}" == "1" ]]; then
  echo "⚠️  已跳过密钥扫描 (SKIP_SECRET_SCAN=1)"
  exit 0
fi

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

FOUND_SECRET=0

# 获取暂存区文件列表
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if [[ -z "$STAGED_FILES" ]]; then
  exit 0
fi

# -------- 扫描单个文件 --------
scan_file() {
  local file="$1"
  local content
  content=$(git show ":$file" 2>/dev/null || true)
  if [[ -z "$content" ]]; then
    return
  fi

  local line_num=0
  local hit_name=""
  local hit_line=""

  while IFS= read -r line; do
    line_num=$((line_num + 1))

    # AWS Access Key ID
    if echo "$line" | grep -qE 'AKIA[0-9A-Z]{16}'; then
      hit_name="AWS Access Key ID (AKIA...)"
      hit_line="$line"
    # GitHub Personal Access Token
    elif echo "$line" | grep -qE 'ghp_[0-9a-zA-Z]{36}'; then
      hit_name="GitHub Personal Access Token (ghp_...)"
      hit_line="$line"
    # GitHub OAuth Token
    elif echo "$line" | grep -qE 'gho_[0-9a-zA-Z]{36}'; then
      hit_name="GitHub OAuth Token (gho_...)"
      hit_line="$line"
    # GitHub tokens (其他前缀)
    elif echo "$line" | grep -qE 'gh[usr]_[0-9a-zA-Z]{36}'; then
      hit_name="GitHub Token"
      hit_line="$line"
    # OpenAI / AI API Key
    elif echo "$line" | grep -qE 'sk-[a-zA-Z0-9]{20,}'; then
      hit_name="AI API Key (sk-...)"
      hit_line="$line"
    # Anthropic API Key
    elif echo "$line" | grep -qE 'sk-ant-[a-zA-Z0-9]{20,}'; then
      hit_name="Anthropic API Key (sk-ant-...)"
      hit_line="$line"
    # Private Key (PEM)
    elif echo "$line" | grep -qE '-----BEGIN (RSA|EC|DSA|OPENSSH) PRIVATE KEY-----'; then
      hit_name="Private Key (PEM)"
      hit_line="$line"
    # API Key 赋值
    elif echo "$line" | grep -qiE 'api[_-]?key\s*[:=]\s*['"'"'"]?[a-zA-Z0-9_\-]{20,}'; then
      hit_name="API Key 明文赋值"
      hit_line="$line"
    # Secret 明文
    elif echo "$line" | grep -qiE '(secret|密钥)\s*[:=]\s*['"'"'"]?[a-zA-Z0-9_\-]{10,}'; then
      hit_name="Secret 明文赋值"
      hit_line="$line"
    # Password 明文
    elif echo "$line" | grep -qiE 'password\s*[:=]\s*['"'"'"]?[^'"'"'"]+'; then
      hit_name="Password 明文赋值"
      hit_line="$line"
    # Token 明文
    elif echo "$line" | grep -qiE 'token\s*[:=]\s*['"'"'"]?[a-zA-Z0-9_\-\.]{20,}'; then
      hit_name="Token 明文赋值"
      hit_line="$line"
    # JWT
    elif echo "$line" | grep -qE 'eyJ[a-zA-Z0-9_\-]{20,}\.[a-zA-Z0-9_\-]{20,}\.[a-zA-Z0-9_\-]{1,}'; then
      hit_name="JWT Token"
      hit_line="$line"
    # 数据库连接串(含密码)
    elif echo "$line" | grep -qiE '(mongodb|mysql|postgres|postgresql|redis)://[^:]+:[^@]+@'; then
      hit_name="数据库连接字符串(含密码)"
      hit_line="$line"
    fi

    if [[ -n "$hit_name" ]]; then
      if [[ $FOUND_SECRET -eq 0 ]]; then
        echo ""
        echo -e "${RED}╔══════════════════════════════════════════════════════════╗${NC}"
        echo -e "${RED}║  🔴 发现疑似敏感信息！提交已被阻止。                    ║${NC}"
        echo -e "${RED}╚══════════════════════════════════════════════════════════╝${NC}"
        echo ""
      fi
      FOUND_SECRET=1
      echo -e "${YELLOW}📄 ${file}:${line_num}${NC} — ${RED}${hit_name}${NC}"
      echo "   ${hit_line}"
      hit_name=""
    fi
  done <<< "$content"
}

# -------- 遍历暂存文件 --------
for file in $STAGED_FILES; do
  # 跳过 .gitignore 中已忽略的文件
  if git check-ignore -q "$file" 2>/dev/null; then
    continue
  fi
  scan_file "$file"
done

if [[ $FOUND_SECRET -eq 1 ]]; then
  echo ""
  echo -e "${YELLOW}💡 提示：${NC}"
  echo "   • 假阳性 → SKIP_SECRET_SCAN=1 git commit ..."
  echo "   • 测试数据 → 移入 .env.example，用占位符替换"
  echo "   • 真实密钥 → 立即轮换！已暂存的内容可能已泄露"
  echo ""
  exit 1
fi

exit 0
